# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1
LOG_LEVEL=debug

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?appName=Artha
MONGODB_TEST_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?appName=Artha

# Blackhole auth — JWT_SECRET must match the auth Render service exactly
JWT_SECRET=blackhole-auth-super-secure-random-secret-min-32-chars
AUTH_SERVER_URL=https://bhiv-auth.onrender.com

# Public base URL of THIS API (no trailing slash). Callback: {APP_URL}/auth/callback
# Example production: https://your-artha-api.onrender.com
APP_URL=http://localhost:5000

# SPA origin (no trailing slash). Used after /auth/callback redirect to dashboard.
FRONTEND_URL=http://localhost:5173
# Comma-separated browser origins allowed for credentialed CORS (must match Origin header exactly).
# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
# Local dev origins (Vite) are allowed by default. Set false on strict production-only APIs.
# ALLOW_LOCALHOST_CORS=false

# If true, login email step must match an active row in local User collection (legacy).
# Leave false/unset when identity is only Blackhole (recommended).
# REQUIRE_LOCAL_EMAIL_FOR_LOGIN=false

# Access control: JWT claim allowedApps must include this (setu | sampada | niyantran | …)
# Leave unset to skip enforcement (not recommended in production).
# APP_ID=setu

# Legacy alias for APP_ID (either may be set)
# BHIV_APP_ID=setu

# Security
HMAC_SECRET=your-hmac-secret-for-ledger-chain
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# InsightCore
INSIGHTCORE_ENDPOINT=http://localhost:8000/telemetry
INSIGHTCORE_ENABLED=false

# Storage for expenses
STORAGE_TYPE=local
AWS_BUCKET_NAME=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
