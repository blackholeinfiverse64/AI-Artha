# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1
LOG_LEVEL=debug

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?appName=Artha
MONGODB_TEST_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?appName=Artha

# Blackhole central auth (JSON APIs only — no hosted login UI)
# JWT_SECRET must match the auth service exactly.
JWT_SECRET=blackhole-auth-super-secure-random-secret-min-32-chars
AUTH_SERVER_URL=https://bhiv-auth.onrender.com

# --- URLs (pick ONE style) ---
# Legacy (still supported): API base + SPA
#   APP_URL = this API’s public base (http://localhost:5000 or https://api.example.com)
#   FRONTEND_URL = SPA (http://localhost:5173 or https://app.example.com)
# New: SPA-only APP_URL + explicit API
#   APP_URL = SPA origin only
#   API_PUBLIC_URL = this API’s public base (required in production when SPA is not on API host)

APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
# API_PUBLIC_URL=https://your-api.onrender.com

# Optional: full URL where unauthenticated users should go (default: {SPA}/login)
# APP_LOGIN_URL=https://ai-artha.vercel.app/login

# Comma-separated CORS browser origins (must match Origin header; credentialed requests).
# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
# ALLOW_LOCALHOST_CORS=false

# If true, magic-link / validate-login-email must match an active local User row.
# REQUIRE_LOCAL_EMAIL_FOR_LOGIN=false

# JWT allowedApps must include this id (configure on auth server).
# APP_ID=artha
# BHIV_APP_ID=artha

# Security
HMAC_SECRET=your-hmac-secret-for-ledger-chain
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# AUTH_PASSWORD_RATE_LIMIT_MAX=10
# AUTH_MAGIC_RATE_LIMIT_MAX=100
# TRUST_PROXY=0  # set to disable trust proxy (default: on for Render)

# InsightCore
INSIGHTCORE_ENDPOINT=http://localhost:8000/telemetry
INSIGHTCORE_ENABLED=false

# Storage for expenses
STORAGE_TYPE=local
AWS_BUCKET_NAME=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
