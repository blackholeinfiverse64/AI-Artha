# Server
NODE_ENV=production
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb+srv://blackholeinfiverse54_db_user:Gjpl998Z6hsQLjJF@artha.rzneis7.mongodb.net/?appName=Artha

# Blackhole Auth (centralized SSO)
JWT_SECRET=blackhole-auth-super-secure-random-secret-min-32-chars
AUTH_SERVER_URL=https://auth.blackholeinfiverse.com

# Security (CHANGE THIS!)
HMAC_SECRET=YOUR_SUPER_SECRET_HMAC_KEY_FOR_LEDGER_CHAIN_MINIMUM_32_CHARACTERS

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis (Production Only)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0

# InsightCore (Optional)
INSIGHTCORE_ENDPOINT=http://your-insightcore-service/telemetry
INSIGHTCORE_ENABLED=false
INSIGHTCORE_API_KEY=

# Storage
STORAGE_TYPE=local
AWS_BUCKET_NAME=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend URL (SPA). Also list extra origins in CORS_ORIGIN or CORS_ALLOWED_ORIGINS (comma-separated).
FRONTEND_URL=https://your-domain.com
# CORS_ORIGIN=https://your-domain.com
# Local Vite is allowed unless you set: ALLOW_LOCALHOST_CORS=false

# Admin Seed (managed by Blackhole Auth)
# ADMIN_EMAIL=admin@your-domain.com

# Logging
LOG_LEVEL=info