HMAC_SECRET=YOUR_SUPER_SECRET_HMAC_KEY_FOR_LEDGER_CHAIN

# Public SPA URL (no trailing slash) — set per deployment target
# Vercel: VITE_APP_URL=https://ai-artha.vercel.app
# Custom domain: VITE_APP_URL=https://artha.blackholeinfiverse.com
VITE_APP_URL=https://ai-artha.vercel.app

# API URL for frontend (Render API + /api/v1). If omitted, frontend auto-uses:
# - localhost -> http://localhost:5000/api/v1
# - production host -> {window.location.origin}/api/v1
VITE_API_URL=https://ai-artha.onrender.com/api/v1
VITE_API_ORIGIN=https://ai-artha.onrender.com

# Auth callback is on the API: https://ai-artha.onrender.com/auth/callback (override only if needed)
# VITE_AUTH_CALLBACK_URL=https://ai-artha.onrender.com/auth/callback
VITE_AUTH_SERVER_URL=https://bhiv-auth.onrender.com
VITE_AUTH_MESSAGE_ORIGIN=https://bhiv-auth.onrender.com